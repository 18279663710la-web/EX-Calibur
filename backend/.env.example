# ============================================================
# CloudRAG-Hub Backend 环境变量配置
# 复制此文件为 .env 并填入真实值
# ============================================================

# --- 服务 ---
APP_NAME=CloudRAG-Hub
APP_VERSION=1.0.0
DEBUG=true
HOST=0.0.0.0
PORT=8080

# --- JWT ---
JWT_SECRET_KEY=change-me-to-a-random-64-char-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_SECONDS=7200
REFRESH_TOKEN_EXPIRE_SECONDS=604800

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=cloudrag
POSTGRES_USER=cloudrag
POSTGRES_PASSWORD=change-me

# --- Dify AI Platform ---
DIFY_BASE_URL=http://localhost/v1
DIFY_API_KEY=app-4352a1bfc95a41dd
DIFY_TIMEOUT_SECONDS=120

# --- 上传限制 ---
MAX_UPLOAD_SIZE_MB=50
UPLOAD_DIR=./uploads
