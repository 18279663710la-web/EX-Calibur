# ============================================================
# CloudRAG-Hub 环境变量配置
# 复制此文件为 .env，仅需填写标注 [必须] 的项即可启动
# ============================================================

# ---- 服务基础配置 ----
APP_NAME=CloudRAG-Hub
APP_VERSION=1.0.5
DEBUG=false
BACKEND_PORT=8080
FRONTEND_PORT=8081
AGENT_PORT=8090

# ---- JWT 认证（首次启动自动生成，无需手动填写）----
# 留空则自动生成 256-bit 随机密钥，持久化存储不会丢失
# 如需固定密钥，取消下一行注释并填写：
# JWT_SECRET_KEY=your-custom-key
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_SECONDS=7200
REFRESH_TOKEN_EXPIRE_SECONDS=604800

# ---- PostgreSQL 数据库 ----
POSTGRES_DB=cloudrag
POSTGRES_USER=cloudrag
POSTGRES_PASSWORD=MyCloud@2026

# ---- Dify AI 平台 [必须] ----
# 本地 Docker 部署的 Dify（默认值，无需修改）：
# DIFY_BASE_URL=http://api:5001/v1
# Dify Cloud 用户使用：
# DIFY_BASE_URL=https://api.dify.ai/v1
# 宿主机上的 Dify（非 Docker），使用：
# DIFY_BASE_URL=http://host.docker.internal/v1
DIFY_BASE_URL=http://api:5001/v1
DIFY_API_KEY=                    # [必须] Dify 控制台 → 发布应用 → 复制 API Key
DIFY_TIMEOUT_SECONDS=120

# Dify 内部管理 API Key（预留，当前代码未使用，无需填写）
DIFY_INTERNAL_KEY=

# ---- 知识库自动同步（可选，启用文档清洗上传功能）----
# 留空则同步容器保持运行但跳过上传，不影响 Web 和微信功能
DIFY_DATASET_API_KEY=            # [可选] Dify 控制台 → 知识库 → API 管理
DIFY_DATASET_ID=                 # [可选] Dify 控制台 → 知识库 → 设置
DIFY_DATASET_UPLOAD_TIMEOUT=300
SYNC_INTERVAL_SECONDS=60         # 同步间隔，单位秒
SYNC_RUN_ON_START=true           # 容器启动时立即运行一次同步
SYNC_ONCE=false                  # true 则只同步一次后退出
RAG_SYNC_PIPELINE=deepseek       # direct=原文件直传，deepseek=AI 清洗后上传

# ---- 文档清洗模型配置（可选，deepseek 管线需要）----
# DeepSeek 官方 API：
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-v4-pro
# 阿里云百炼兼容端点：
# DEEPSEEK_BASE_URL=https://your-workspace-id.cn-beijing.maas.aliyuncs.com/compatible-mode/v1
# DEEPSEEK_MODEL=qwen3.7-plus
CLOUDRAG_DEEPSEEK_API_KEY=       # [可选] platform.deepseek.com/api_keys 获取
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro

# ---- 微信 / iLink Clawbot 通道（可选，扫码即可连接）----
# 无需预先配置 token，Web 端点击连接 → 扫码 → 动态获取 token
WEIXIN_BASE_URL=https://ilinkai.weixin.qq.com
WEIXIN_CDN_BASE_URL=https://novac2c.cdn.weixin.qq.com/c2c
WEIXIN_TOKEN=

# ---- 上传限制 ----
MAX_UPLOAD_SIZE_MB=15

# ---- Agent 文件服务 ----
AGENT_KNOWLEDGE_DIR=knowledge
