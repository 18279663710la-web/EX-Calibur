# ============================================================
# CloudRAG-Hub 环境变量配置
# 复制此文件为 .env，优先填写下方配置填写区域
# ============================================================

# ---- 服务基础配置 ----
APP_NAME=CloudRAG-Hub
APP_VERSION=1.0.5
CLOUDRAG_DEBUG=false
BACKEND_PORT=8080
FRONTEND_PORT=8081
AGENT_PORT=8090
# ============此为配置填写区域===================
POSTGRES_PASSWORD=MyCloud@2026
DIFY_BASE_URL=http://api:5001/v1
DIFY_API_KEY=
DIFY_DATASET_API_KEY=
DIFY_DATASET_ID=
CLEANING_MODEL_API_KEY=
CLEANING_MODEL_BASE_URL=https://api.deepseek.com
CLEANING_MODEL_NAME=deepseek-chat
AGENT_PUBLIC_BASE_URL=http://你的电脑局域网IP:8090

# =============================================
# ---- JWT 认证（首次启动自动生成，无需手动填写）----
# 留空则自动生成 256-bit 随机密钥，持久化存储不会丢失
# 如需固定密钥，取消下一行注释并填写：
# JWT_SECRET_KEY=your-custom-key
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_SECONDS=7200
REFRESH_TOKEN_EXPIRE_SECONDS=604800

# ---- PostgreSQL 数据库 ----
POSTGRES_DB=cloudrag
POSTGRES_USER=cloudrag

DIFY_TIMEOUT_SECONDS=120
DIFY_INTERNAL_KEY=

# ---- 知识库自动同步----
DIFY_DATASET_UPLOAD_TIMEOUT=300
SYNC_INTERVAL_SECONDS=60         # 同步间隔，单位秒
SYNC_RUN_ON_START=true           # 容器启动时立即运行一次同步
SYNC_ONCE=false                  # true 则只同步一次后退出
RAG_SYNC_PIPELINE=model          # direct=原文件直传，model=通用模型清洗后上传

# ---- 微信 / iLink Clawbot 通道（可选，扫码即可连接）----
# 无需预先配置 token，Web 端点击连接 → 扫码 → 动态获取 token
WEIXIN_BASE_URL=https://ilinkai.weixin.qq.com
WEIXIN_CDN_BASE_URL=https://novac2c.cdn.weixin.qq.com/c2c
WEIXIN_TOKEN=

# ---- 上传限制 ----
MAX_UPLOAD_SIZE_MB=15

# ---- Agent 文件服务 ----
AGENT_KNOWLEDGE_DIR=knowledge
AGENT_DOWNLOAD_SECRET=change-me-agent-download-secret
