# CloudRAG-Hub runtime configuration
# Copy this file to .env and fill in your own secrets.

APP_NAME=CloudRAG-Hub
APP_VERSION=1.0.0
DEBUG=false
BACKEND_PORT=8080
FRONTEND_PORT=8081
AGENT_PORT=8090

# JWT
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=change-me-to-a-random-64-character-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_SECONDS=7200
REFRESH_TOKEN_EXPIRE_SECONDS=604800

# CloudRAG PostgreSQL
POSTGRES_DB=cloudrag
POSTGRES_USER=cloudrag
POSTGRES_PASSWORD=change-me

# Dify app API
# For local Dify started from C:\dify\docker, CloudRAG joins docker_default and uses:
# DIFY_BASE_URL=http://api:5001/v1
# If CloudRAG is not attached to the Dify Docker network, use:
# DIFY_BASE_URL=http://host.docker.internal/v1
# For public Dify Cloud, use:
# DIFY_BASE_URL=https://api.dify.ai/v1
DIFY_BASE_URL=http://api:5001/v1
DIFY_API_KEY=
DIFY_TIMEOUT_SECONDS=120

# Optional: used only by internal Dify sync helpers.
DIFY_INTERNAL_KEY=

# Optional: Dify knowledge-base auto sync.
# Keep blank to start the sync container in idle mode.
DIFY_DATASET_API_KEY=
DIFY_DATASET_ID=
DIFY_DATASET_UPLOAD_TIMEOUT=300
SYNC_INTERVAL_SECONDS=60
SYNC_RUN_ON_START=true
SYNC_ONCE=false
RAG_SYNC_PIPELINE=deepseek
# Text cleaning uses an OpenAI-compatible chat-completions endpoint.
# DeepSeek example:
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_MODEL=deepseek-v4-pro
# Alibaba Cloud Model Studio / Bailian example:
# DEEPSEEK_BASE_URL=https://your-workspace-id.cn-beijing.maas.aliyuncs.com/compatible-mode/v1
# DEEPSEEK_MODEL=qwen3.7-plus
CLOUDRAG_DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-pro

# Optional: WeChat / iLink Clawbot channel
WEIXIN_BASE_URL=https://ilinkai.weixin.qq.com
WEIXIN_CDN_BASE_URL=https://novac2c.cdn.weixin.qq.com/c2c
WEIXIN_TOKEN=

# Upload limits
MAX_UPLOAD_SIZE_MB=15

# Agent file service
AGENT_KNOWLEDGE_DIR=knowledge
